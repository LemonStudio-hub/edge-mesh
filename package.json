{
  "name": "edge-mesh",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "description": "Browser-side P2P file distribution network",
  "scripts": {
    "dev": "pnpm -C packages/frontend dev",
    "build": "pnpm -r build",
    "worker:dev": "pnpm -C packages/worker dev",
    "worker:deploy": "pnpm -C packages/worker deploy",
    "wasm:build": "cd packages/worker/src/wasm/edge-mesh-crypto && wasm-pack build --target web --out-dir ../../../pkg",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf node_modules dist pkg target"
  },
  "engines": {
    "node": ">=18"
  }
}
